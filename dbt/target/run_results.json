us\n\nFROM base", "relation_name": "ecommerce_db.ANALYTICS.orders_status", "batch_results": null}], "elapsed_time": 18.138761043548584, "args": {"state_modified_compare_more_unrendered_values": false, "static_parser": true, "vars": {}, "empty": false, "project_dir": "/usr/app", "state_modified_compare_vars": false, "warn_error_options": {"include": [], "exclude": []}, "log_format_file": "debug", "partial_parse": true, "quiet": false, "use_colors": true, "show_resource_report": false, "require_explicit_package_overrides_for_builtin_materializations": true, "strict_mode": false, "which": "run", "invocation_command": "dbt run --project-dir /usr/app", "log_level": "info", "use_colors_file": true, "version_check": true, "require_resource_names_without_spaces": false, "send_anonymous_usage_stats": true, "log_path": "/usr/app/logs", "populate_cache": true, "favor_state": false, "macro_debugging": false, "require_yaml_configuration_for_mf_time_spines": false, "require_nested_cumulative_type_params": false, "exclude": [], "defer": false, "log_file_max_bytes": 10485760, "profiles_dir": "/usr/app", "print": true, "introspect": true, "select": [], "write_json": true, "require_batched_execution_for_custom_microbatch_strategy": false, "log_level_file": "debug", "cache_selected_only": false, "skip_nodes_if_on_run_start_fails": false, "printer_width": 80, "indirect_selection": "eager", "log_format": "default", "source_freshness_run_project_hooks": false, "partial_parse_file_diff": true}}